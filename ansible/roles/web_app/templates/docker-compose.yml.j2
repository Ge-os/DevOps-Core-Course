# Managed by Ansible (role: web_app)
# Variables: app_name, docker_image, docker_tag, app_port, app_internal_port, app_env_vars
version: '{{ docker_compose_version }}'

services:
  {{ app_name }}:
    image: {{ docker_image }}:{{ docker_tag }}
    container_name: {{ app_name }}
    ports:
      - "{{ app_port }}:{{ app_internal_port }}"
    environment:
{% for key, value in app_env_vars.items() %}
      {{ key }}: "{{ value }}"
{% endfor %}
    restart: {{ app_restart_policy }}

networks:
  default:
    name: {{ app_name }}-network
